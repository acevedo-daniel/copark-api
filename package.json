{
  "name": "parkcore-api",
  "version": "1.0.0",
  "description": "Parking management backend API",
  "type": "module",
  "main": "server.ts",
  "scripts": {
    "dev": "tsx watch server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "start:dev": "tsx server.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "prebuild": "pnpm clean",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:reset": "prisma migrate reset",
    "prisma:studio": "prisma studio",
    "prisma:seed": "prisma db seed",
    "db:setup": "pnpm prisma:generate && pnpm prisma:migrate:deploy && pnpm prisma:seed",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:reset": "docker compose down -v && docker compose up -d",
    "docker:logs": "docker compose logs -f",
    "docker:ps": "docker compose ps",
    "generate:openapi": "tsx src/scripts/generate-openapi.ts",
    "openapi:check": "tsx src/scripts/check-openapi.ts",
    "build:check": "pnpm build && tsx src/scripts/check-build-artifact.ts",
    "release:readiness": "pnpm openapi:check && pnpm build:check",
    "smoke:local": "tsx src/scripts/smoke-local.ts",
    "smoke:remote": "tsx src/scripts/smoke-api.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "quality": "pnpm lint && pnpm typecheck && pnpm test",
    "quality:ci": "pnpm lint && pnpm typecheck && pnpm test:coverage && pnpm generate:openapi"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@scalar/express-api-reference": "^0.8.48",
    "argon2": "^0.44.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jose": "^6.2.2",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "pino-pretty": "^13.1.3",
    "prettier": "3.8.1",
    "prisma": "^7.7.0",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1",
    "vite": "^7.3.2",
    "vitest": "^4.1.4"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "lodash": "^4.17.23",
      "qs@>=6.7.0 <=6.14.1": ">=6.14.2",
      "minimatch@<10.2.1": ">=10.2.1",
      "vite@>=7.0.0 <=7.3.1": ">=7.3.2",
      "vite@>=7.1.0 <=7.3.1": ">=7.3.2",
      "@hono/node-server@<1.19.13": ">=1.19.13"
    }
  }
}
