# CoPark API - Environment Configuration
# Copy this file to .env and replace placeholder values.

# Runtime
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# Security
# In production, CORS_ORIGINS is required (comma-separated list).
# Example: https://app.example.com,https://admin.example.com
CORS_ORIGINS=http://localhost:5173
JWT_SECRET=replace-with-32-plus-chars-secret
JWT_EXPIRES_IN=24h

# Logging (Pino)
LOG_LEVEL=info
LOG_PRETTY=true

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/copark?schema=public

# Docker PostgreSQL (local only)
POSTGRES_USER=copark
POSTGRES_PASSWORD=copark
POSTGRES_DB=copark
