# CoPark API - Environment Configuration
# Copy this file to .env and replace placeholder values.

# Runtime
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000
# Production (Render):
# API_BASE_URL=https://copark-api.onrender.com

# Security
# In production, CORS_ORIGINS is required (comma-separated list).
# Example: https://app.example.com,https://admin.example.com
CORS_ORIGINS=http://localhost:5173
JWT_SECRET=replace-with-32-plus-chars-secret
JWT_EXPIRES_IN=24h
AUTH_RATE_LIMIT_MAX=15
AUTH_RATE_LIMIT_WINDOW_MS=900000
# Optional: enables distributed rate limiting across multiple app instances.
# Example (Render/managed Redis): rediss://default:<password>@<host>:<port>
REDIS_URL=

# Logging (Pino)
LOG_LEVEL=info
LOG_PRETTY=true

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/copark?schema=public

# Docker PostgreSQL (local only)
POSTGRES_USER=copark
POSTGRES_PASSWORD=copark
POSTGRES_DB=copark
